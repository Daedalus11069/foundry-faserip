{
  "private": true,
  "name": "foundry-faserip",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run unlink-dev && npm run link-dev && vite",
    "dev-remote": "npm run unlink-dev && npm run link-dev && vite --port 30001",
    "build": "vite build",
    "auto-build": "node auto-build.cjs",
    "preview": "vite preview",
    "preview-remote": "npm run unlink-dev && npm run link-dev-dist && vite preview --port 30001",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "patch-package",
    "link-dev": "./linkDevEnv.bat",
    "link-dev-dist": "./linkDevEnvDist.bat",
    "unlink-dev": "./unlinkDevEnv.bat",
    "relink-dist": "npm run unlink-dev && npm run link-dev-dist"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.0.9",
    "tailwindcss": "^4.0.4",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.20",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#v13.345.1",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.1",
    "sass-embedded": "^1.83.4",
    "typescript": "~5.8.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.3.3",
    "vite-plugin-static-copy": "^4.1.0",
    "vue-tsc": "^2.2.0"
  }
}
