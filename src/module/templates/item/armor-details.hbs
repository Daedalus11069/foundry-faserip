<div class="tab details" data-group="primary" data-tab="details">
  <div class="p-4 space-y-6">
    <!-- Protection Rating Section -->
    <div class="bg-gray-900/50 rounded-lg p-4 border border-gray-700">
      <h3 class="text-lg font-bold text-blue-400 mb-3 flex items-center gap-2">
        <i class="fas fa-shield-alt"></i>
        Protection Rating
      </h3>
      
      <div class="form-group mb-4">
        <label class="text-sm font-semibold text-gray-300 mb-1 block">Armor Rank</label>
        <select name="system.rank" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white hover:border-blue-500 transition-colors">
          {{#each ranks}}
          <option value="{{value}}" {{#if (eq ../system.rank value)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <p class="text-xs text-gray-400 mt-1">
          <i class="fas fa-info-circle"></i> The rank of protection this armor provides against attacks
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="form-group">
          <label class="text-sm font-semibold text-gray-300 mb-1 block">Current Armor</label>
          <input 
            type="number" 
            name="system.value" 
            value="{{system.value}}" 
            min="0" 
            max="{{system.maxValue}}"
            class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white hover:border-blue-500 transition-colors" 
          />
          <p class="text-xs text-gray-400 mt-1">
            <i class="fas fa-heart"></i> Current durability
          </p>
        </div>

        <div class="form-group">
          <label class="text-sm font-semibold text-gray-300 mb-1 block">Maximum Armor</label>
          <input 
            type="number" 
            name="system.maxValue" 
            value="{{system.maxValue}}" 
            min="0" 
            class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white hover:border-blue-500 transition-colors" 
          />
          <p class="text-xs text-gray-400 mt-1">
            <i class="fas fa-tools"></i> Maximum when fully repaired
          </p>
        </div>
      </div>

      <!-- Damage indicator -->
      {{#if (gt system.maxValue system.value)}}
      <div class="mt-3 p-2 bg-yellow-900/30 border border-yellow-600/50 rounded text-yellow-400 text-sm flex items-center gap-2">
        <i class="fas fa-exclamation-triangle"></i>
        <span>Damaged: {{system.value}}/{{system.maxValue}} remaining ({{subtract system.maxValue system.value}} damage taken)</span>
      </div>
      {{else}}
      <div class="mt-3 p-2 bg-green-900/30 border border-green-600/50 rounded text-green-400 text-sm flex items-center gap-2">
        <i class="fas fa-check-circle"></i>
        <span>Armor is in perfect condition</span>
      </div>
      {{/if}}
    </div>

    <!-- Equipment Status Section -->
    <div class="bg-gray-900/50 rounded-lg p-4 border border-gray-700">
      <h3 class="text-lg font-bold text-blue-400 mb-3 flex items-center gap-2">
        <i class="fas fa-user-shield"></i>
        Equipment Status
      </h3>
      
      <div class="form-group">
        <label class="flex items-center gap-3 cursor-pointer hover:bg-gray-800/50 p-2 rounded transition-colors">
          <input 
            type="checkbox" 
            name="system.equipped" 
            {{checked system.equipped}} 
            class="w-5 h-5 rounded border-gray-600 text-blue-500 focus:ring-blue-500 focus:ring-offset-gray-900" 
          />
          <div>
            <span class="text-sm font-semibold text-gray-300 block">Currently Equipped</span>
            <span class="text-xs text-gray-400">Check this if the character is wearing this armor</span>
          </div>
        </label>
      </div>

      {{#if system.equipped}}
      <div class="mt-3 p-3 bg-green-900/30 border border-green-600/50 rounded text-green-400 text-sm flex items-center gap-2">
        <i class="fas fa-check"></i>
        <span class="font-semibold">This armor is actively protecting the character</span>
      </div>
      {{else}}
      <div class="mt-3 p-2 bg-gray-800/50 border border-gray-600/50 rounded text-gray-400 text-sm flex items-center gap-2">
        <i class="fas fa-box"></i>
        <span>This armor is stored in inventory</span>
      </div>
      {{/if}}
    </div>

    <!-- Quick Reference -->
    <div class="bg-blue-900/20 border border-blue-700/50 rounded p-3">
      <h4 class="text-sm font-bold text-blue-300 mb-2 flex items-center gap-2">
        <i class="fas fa-book"></i>
        Armor Rules
      </h4>
      <ul class="text-xs text-gray-400 space-y-1">
        <li><i class="fas fa-chevron-right text-blue-500"></i> Only one armor can be equipped at a time</li>
        <li><i class="fas fa-chevron-right text-blue-500"></i> Armor rank reduces incoming damage by shifting columns</li>
        <li><i class="fas fa-chevron-right text-blue-500"></i> If degrading armor is enabled, damage reduces current armor value</li>
        <li><i class="fas fa-chevron-right text-blue-500"></i> When armor value reaches 0, the armor is destroyed</li>
      </ul>
    </div>
  </div>
</div>
